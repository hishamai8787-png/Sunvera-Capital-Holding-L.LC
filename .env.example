# Sunvera Capital — Environment Variables

# Financial data APIs
FMP_API_KEY=your_fmp_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# API authentication (for programmatic/external access)
APP_API_TOKEN=

# Database — Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_or_publishable_key
# IMPORTANT: Do NOT set SUPABASE_SERVICE_ROLE_KEY in the app.
# The service role key bypasses all Row Level Security policies.
# It should only be used in Supabase admin scripts, never in the app.

# NextAuth.js authentication
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@sunveracapital.com
# Generate a bcrypt hash: node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash

# Rate limiting — Upstash Redis (optional but recommended for production)
# Without Redis, in-memory rate limiting is used (single-instance only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
