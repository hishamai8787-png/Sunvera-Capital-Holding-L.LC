# Sunvera Analyst — Environment Variables

# Financial data APIs
FMP_API_KEY=your_fmp_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# API authentication (for programmatic/external access)
# Leave unset to allow same-origin frontend calls only.
# Set to a strong random string to enable external API access via Bearer token.
APP_API_TOKEN=

# Database (when migrated from filesystem)
# DATABASE_URL=postgresql://user:password@host:5432/sunvera
