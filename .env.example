# Sunvera Capital — Environment Variables

# ============================================================
# SECURITY (required for production)
# ============================================================

# NextAuth.js authentication
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@sunveracapital.com
# Generate a bcrypt hash: node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash

# Two-Factor Authentication (TOTP — RFC 6238)
# Generate a TOTP secret: node -e "const {authenticator}=require('otplib'); console.log(authenticator.generateSecret())"
# Then scan the QR code at /settings with Google Authenticator, Authy, etc.
# Optional: if not set, 2FA is disabled
TOTP_SECRET=

# API authentication (for programmatic/external access)
# Generate: openssl rand -hex 32
APP_API_TOKEN=

# ============================================================
# DATABASE (required for production)
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_or_publishable_key
# Supabase service role key — server-side ONLY (bypasses RLS for admin operations)
# NEVER expose this to the client. Used by lib/db.ts for server-side DB operations.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# FINANCIAL DATA (optional — free fallbacks included)
# ============================================================

FMP_API_KEY=your_fmp_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# ============================================================
# RATE LIMITING (optional but recommended for production)
# ============================================================

# Without Redis, in-memory rate limiting is used (single-instance only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# MONITORING (optional)
# ============================================================

# Sentry error monitoring — get DSN from https://sentry.io
SENTRY_DSN=
SENTRY_DEV=false

# ============================================================
# SITE CONFIG
# ============================================================

# Public site URL (for SEO canonical URLs and OG metadata)
NEXT_PUBLIC_SITE_URL=https://sunveracapital.com
